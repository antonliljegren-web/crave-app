      ${r.formatted_phone_number?`<div class="det-row"><div class="det-ico">📞</div><div class="det-txt">${r.formatted_phone_number}</div></div>`:''}
      ${r.website?`<div class="det-row"><div class="det-ico">🌐</div><div class="det-txt"><a href="${r.website}" target="_blank">${r.website}</a></div></div>`:''}
      <div class="det-ctas">
        <a class="det-cta dc-maps" href="${maps}" target="_blank">🗺 Maps</a>
        ${r.website?`<a class="det-cta dc-web" href="${r.website}" target="_blank">🌐 Website</a>`:''}
        ${r.formatted_phone_number?`<a class="det-cta dc-call" href="tel:${r.formatted_phone_number}">📞 Call</a>`:''}
      </div>
    </div>`;
}
function closeDetail() { document.getElementById('detail-modal').style.display='none'; }

// ════════════════════════════════════════════════════
//  HELPERS
// ════════════════════════════════════════════════════
function toast(msg, type='default') {
  const t = document.getElementById('toast');
  t.textContent=msg; t.className='toast '+type; t.classList.add('show');
  clearTimeout(t._tid);
  t._tid=setTimeout(()=>t.classList.remove('show'), type==='match'?3200:2400);
}
function updateStreak() {
  const p=document.getElementById('streak-pill');
  document.getElementById('streak-num').textContent=streak;
  p.style.display=streak>1?'flex':'none';
}

document.addEventListener('keydown', e => {
  if (document.getElementById('app').style.display==='none') return;
  if (e.key==='ArrowRight') swipeCard('right');
  if (e.key==='ArrowLeft')  swipeCard('left');
  if (e.key==='i'||e.key==='I') showDetail(currentR());
  if (e.key==='z'||e.key==='Z') rewind();
});

// On load: check for join URL
window.addEventListener('load', () => {
  const p=new URLSearchParams(window.location.search);
  if (p.get('join')) showJoin();
  updateLibBadge();
  updateStreak();
});
</script>
</body>
</html>
