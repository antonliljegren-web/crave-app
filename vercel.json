  const stars= r.rating?'★'.repeat(Math.floor(r.rating))+(r.rating%1>=.5?'½':''):'';

  sheet.innerHTML = `
    <button class="det-close" onclick="closeDetail()">✕</button>
    ${src?`<img class="det-photo" src="${src}" alt="${r.name}">`:`<div class="det-ph">${em}</div>`}
    <div class="det-body">
      <div class="det-cuisine">${(r.cuisine||'Restaurant').toUpperCase()}</div>
      <div class="det-name">${r.name}</div>
      ${r.rating?`<p style="margin-bottom:12px;font-size:.88rem;"><span style="color:var(--accent2)">${stars}</span> <strong>${r.rating}</strong> <span style="color:var(--muted)">(${(r.user_ratings_total||0).toLocaleString()} reviews)</span></p>`:''}
