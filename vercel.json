<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Crave — Find Your Next Meal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg:      #FFF8F0;
  --surface: #FFFFFF;
  --border:  #EDE5DB;
  --text:    #1A1208;
  --muted:   #9C8B7A;
  --soft:    #F5EDE3;
  --peach:   #FFE8D6;
  --accent:  #FF6B35;
  --accent2: #FFB347;
  --green:   #2DBE6C;
  --green-bg:#E8F9EF;
  --red:     #FF4757;
  --red-bg:  #FFE8EA;
  --blue:    #4A90E2;
  --blue-bg: #EAF2FF;
  --purple:  #9B59B6;
  --purple-bg:#F3E8FF;
  --shadow:  0 8px 40px rgba(255,107,53,0.10), 0 2px 8px rgba(0,0,0,0.05);
  --shadow-card: 0 16px 48px rgba(255,107,53,0.14), 0 3px 12px rgba(0,0,0,0.07);
  --r: 22px;
}
html,body { height:100%; background:var(--bg); color:var(--text); font-family:'Plus Jakarta Sans',sans-serif; overflow:hidden; }

/* ── SCREENS ─────────────────────────────────────── */
.screen { position:fixed; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:20px; background:var(--bg); z-index:50; overflow-y:auto; }
.screen.hidden { display:none !important; }
.screen-inner { width:100%; max-width:400px; display:flex; flex-direction:column; align-items:center; gap:0; }

/* ── TYPOGRAPHY ──────────────────────────────────── */
.logo-text {
  font-family:'Syne',sans-serif; font-weight:800; letter-spacing:-2px;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.logo-lg { font-size:3.6rem; line-height:1; margin-bottom:6px; }
.logo-sm { font-size:1.7rem; }
.tagline  { font-size:.95rem; color:var(--muted); font-weight:500; margin-bottom:32px; }

/* ── GLASS CARD ──────────────────────────────────── */
.glass {
  background:rgba(255,255,255,0.9); backdrop-filter:blur(12px);
  border:1.5px solid rgba(255,255,255,0.95); border-radius:var(--r);
  padding:26px; width:100%; box-shadow:var(--shadow);
  display:flex; flex-direction:column; gap:18px;
}

/* ── INPUTS ──────────────────────────────────────── */
.field-label { font-family:'Syne',sans-serif; font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:var(--muted); display:block; margin-bottom:7px; }
.text-input { width:100%; background:var(--surface); border:1.5px solid var(--border); border-radius:12px; padding:12px 15px; color:var(--text); font-family:'Plus Jakarta Sans',sans-serif; font-size:.9rem; outline:none; transition:border-color .2s; }
.text-input:focus { border-color:var(--accent); }
.text-input::placeholder { color:var(--muted); }

input[type=range] { width:100%; appearance:none; height:5px; background:var(--border); border-radius:5px; outline:none; cursor:pointer; margin-top:10px; }
input[type=range]::-webkit-slider-thumb { appearance:none; width:22px; height:22px; background:linear-gradient(135deg,var(--accent),var(--accent2)); border-radius:50%; cursor:pointer; box-shadow:0 2px 8px rgba(255,107,53,.38); }

/* ── CHIPS ───────────────────────────────────────── */
.chips { display:flex; flex-wrap:wrap; gap:7px; }
.chip { padding:6px 13px; border-radius:100px; border:1.5px solid var(--border); background:var(--surface); color:var(--muted); font-size:.78rem; font-weight:500; cursor:pointer; transition:all .15s; }
.chip.on { background:var(--peach); border-color:var(--accent); color:var(--accent); font-weight:600; }

/* ── BUTTONS ─────────────────────────────────────── */
.btn { padding:14px 20px; border-radius:13px; border:none; cursor:pointer; font-family:'Syne',sans-serif; font-weight:700; font-size:.92rem; transition:all .18s; display:flex; align-items:center; justify-content:center; gap:8px; letter-spacing:.2px; width:100%; }
.btn:active { transform:scale(.97); }
.btn-primary { background:linear-gradient(135deg,var(--accent),var(--accent2)); color:#fff; box-shadow:0 4px 16px rgba(255,107,53,.32); }
.btn-primary:hover:not(:disabled) { transform:translateY(-1px); box-shadow:0 6px 22px rgba(255,107,53,.42); }
.btn-primary:disabled { opacity:.5; cursor:not-allowed; transform:none; }
.btn-outline { background:transparent; color:var(--muted); border:1.5px solid var(--border); }
.btn-outline:hover { background:var(--soft); color:var(--text); }
.btn-green  { background:linear-gradient(135deg,var(--green),#1aab59); color:#fff; box-shadow:0 4px 16px rgba(45,190,108,.3); }
.btn-green:hover:not(:disabled) { transform:translateY(-1px); }

.divider { display:flex; align-items:center; gap:10px; color:var(--muted); font-size:.76rem; }
.divider::before,.divider::after { content:''; flex:1; height:1px; background:var(--border); }

/* ── MODE SELECTOR ───────────────────────────────── */
.mode-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.mode-card { border:2px solid var(--border); border-radius:16px; padding:16px 12px; cursor:pointer; transition:all .18s; background:var(--surface); text-align:center; display:flex; flex-direction:column; align-items:center; gap:8px; }
.mode-card:hover { border-color:var(--accent); background:var(--peach); }
.mode-card.selected { border-color:var(--accent); background:var(--peach); box-shadow:0 0 0 3px rgba(255,107,53,.12); }
.mode-icon { font-size:2rem; }
.mode-label { font-family:'Syne',sans-serif; font-weight:700; font-size:.9rem; color:var(--text); }
.mode-sub { font-size:.72rem; color:var(--muted); line-height:1.4; }

/* ── SPLASH EMOJI FLOAT ──────────────────────────── */
.float-emojis { font-size:2rem; display:flex; gap:8px; margin-bottom:28px; animation:float 3s ease-in-out infinite; }
@keyframes float { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-7px); } }

/* ── PERKS ───────────────────────────────────────── */
.perks { display:flex; flex-direction:column; gap:8px; background:var(--peach); border-radius:14px; padding:13px 15px; }
.perk { display:flex; align-items:center; gap:10px; font-size:.8rem; color:var(--text); font-weight:500; }
.perk-ico { width:27px; height:27px; background:#fff; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:.9rem; flex-shrink:0; box-shadow:0 1px 4px rgba(0,0,0,.08); }
.auth-toggle { text-align:center; font-size:.8rem; color:var(--muted); }
.auth-toggle a { color:var(--accent); cursor:pointer; font-weight:600; }

/* ── GROUP LOBBY ─────────────────────────────────── */
.member-list { display:flex; flex-direction:column; gap:8px; }
.member-row { display:flex; align-items:center; gap:10px; padding:10px 13px; background:var(--soft); border-radius:12px; }
.member-avatar { width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,var(--accent),var(--accent2)); display:flex; align-items:center; justify-content:center; font-family:'Syne',sans-serif; font-weight:800; font-size:.85rem; color:#fff; flex-shrink:0; }
.member-name { font-weight:600; font-size:.88rem; flex:1; }
.member-prog { font-size:.72rem; color:var(--muted); }
.member-done { color:var(--green); font-size:.75rem; font-weight:700; }

.share-box { background:var(--peach); border:1.5px solid #FFCBA0; border-radius:14px; padding:14px; display:flex; flex-direction:column; gap:10px; }
.share-url { font-family:monospace; font-size:.8rem; color:var(--accent); word-break:break-all; line-height:1.5; }
.copy-btn { padding:8px 14px; border-radius:9px; background:var(--accent); color:#fff; border:none; cursor:pointer; font-family:'Syne',sans-serif; font-weight:700; font-size:.78rem; transition:opacity .15s; align-self:flex-start; }
.copy-btn:hover { opacity:.85; }

/* ── MAIN APP ────────────────────────────────────── */
#app { display:none; height:100vh; flex-direction:column; background:var(--bg); }

.header { display:flex; align-items:center; justify-content:space-between; padding:16px 18px 8px; flex-shrink:0; }
.header-right { display:flex; gap:7px; align-items:center; flex-wrap:wrap; justify-content:flex-end; }

.pill { display:flex; align-items:center; gap:5px; padding:6px 12px; border-radius:100px; border:1.5px solid var(--border); background:var(--surface); font-size:.75rem; font-weight:600; cursor:pointer; transition:all .15s; color:var(--text); font-family:'Plus Jakarta Sans',sans-serif; position:relative; white-space:nowrap; }
.pill:hover { background:var(--soft); }
.pill.streak-pill { background:linear-gradient(135deg,#FFF3E0,#FFE0B2); border-color:#FFCC80; color:#E65100; }
.pill.group-pill  { background:var(--blue-bg); border-color:#C5DEFF; color:var(--blue); }

.badge { position:absolute; top:-5px; right:-5px; background:var(--accent); color:#fff; font-size:.58rem; font-weight:700; width:16px; height:16px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Syne',sans-serif; }

.loc-bar { text-align:center; font-size:.7rem; color:var(--muted); padding:0 18px 4px; flex-shrink:0; font-weight:500; }

/* ── CARD STACK ──────────────────────────────────── */
.stack-wrap { flex:1; display:flex; align-items:center; justify-content:center; padding:4px 18px 0; min-height:0; }
.card-stack { position:relative; width:100%; max-width:370px; height:450px; }

.r-card { position:absolute; inset:0; border-radius:var(--r); overflow:hidden; cursor:grab; user-select:none; transform-origin:center bottom; box-shadow:var(--shadow-card); touch-action:none; background:#f5f0eb; }
.r-card:active { cursor:grabbing; }
.r-card.peek-2 { transform:scale(.88) translateY(32px); z-index:1; pointer-events:none; }
.r-card.peek-1 { transform:scale(.94) translateY(17px); z-index:2; pointer-events:none; }
.r-card.top    { z-index:3; }

.r-photo { width:100%; height:100%; object-fit:cover; display:block; position:absolute; inset:0; }
.r-shimmer { width:100%; height:100%; background:linear-gradient(135deg,#FFE8D6,#FFF0E6); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px; }
.r-shimmer-emoji { font-size:3.5rem; }
.r-shimmer-bar { width:60px; height:4px; background:linear-gradient(90deg,#f0ddd0,#ffe0c8,#f0ddd0); background-size:200% 100%; border-radius:4px; animation:shim 1.3s ease infinite; }
@keyframes shim { 0%{background-position:-200% 0} 100%{background-position:200% 0} }

.r-overlay { position:absolute; bottom:0; left:0; right:0; background:linear-gradient(to top,rgba(10,6,2,.88) 0%,rgba(10,6,2,.48) 55%,transparent 100%); padding:20px 18px 18px; }
.r-cuisine { font-size:.65rem; font-weight:700; text-transform:uppercase; letter-spacing:1.8px; color:var(--accent2); font-family:'Syne',sans-serif; margin-bottom:3px; }
.r-name { font-family:'Syne',sans-serif; font-weight:800; font-size:1.4rem; color:#fff; line-height:1.1; margin-bottom:8px; }
.r-meta { display:flex; gap:10px; flex-wrap:wrap; }
.r-meta span { font-size:.74rem; color:rgba(255,255,255,.82); font-weight:500; }

.swipe-lbl { position:absolute; top:20px; padding:5px 13px; border-radius:8px; border:3px solid; font-family:'Syne',sans-serif; font-weight:800; font-size:1.1rem; letter-spacing:2px; opacity:0; pointer-events:none; }
.lbl-save { left:16px; border-color:var(--green); color:var(--green); transform:rotate(-14deg); }
.lbl-skip { right:16px; border-color:var(--red);   color:var(--red);   transform:rotate(14deg); }

/* WHO ALSO LIKED badge on card */
.also-liked { position:absolute; top:16px; left:50%; transform:translateX(-50%); background:rgba(255,255,255,.92); border-radius:100px; padding:5px 13px; font-size:.72rem; font-weight:700; color:var(--text); display:none; white-space:nowrap; backdrop-filter:blur(4px); }

/* ── ACTION BAR ──────────────────────────────────── */
.action-bar { display:flex; align-items:center; justify-content:center; gap:11px; padding:10px 18px 12px; flex-shrink:0; }
.act { border:none; border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all .15s; flex-shrink:0; }
.act:hover { transform:scale(1.1); }
.act:active { transform:scale(.93); }
.a-undo { width:46px; height:46px; background:var(--surface); border:1.5px solid var(--border); font-size:.95rem; color:var(--muted); }
.a-skip { width:56px; height:56px; background:var(--red-bg); border:1.5px solid #FFCDD1; font-size:1.3rem; color:var(--red); }
.a-save { width:68px; height:68px; background:linear-gradient(135deg,var(--green),#1aab59); font-size:1.55rem; color:#fff; box-shadow:0 6px 20px rgba(45,190,108,.36); }
.a-info { width:46px; height:46px; background:var(--blue-bg); border:1.5px solid #C5DEFF; font-size:.95rem; color:var(--blue); }
.a-dice { width:56px; height:56px; background:var(--purple-bg); border:1.5px solid #DEC5FF; font-size:1.15rem; color:var(--purple); }

.kbd-hint { text-align:center; font-size:.67rem; color:var(--muted); padding-bottom:8px; flex-shrink:0; }
.kbd { background:var(--surface); border:1px solid var(--border); padding:2px 6px; border-radius:4px; font-size:.66rem; }

/* ── CENTER STATES ───────────────────────────────── */
.cstate { display:none; flex-direction:column; align-items:center; justify-content:center; height:100%; gap:13px; text-align:center; padding:24px; }
.spinner { width:40px; height:40px; border:3px solid var(--border); border-top-color:var(--accent); border-radius:50%; animation:spin .75s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }
.cstate-emoji { font-size:3.2rem; }
.cstate-title { font-family:'Syne',sans-serif; font-weight:700; font-size:1.2rem; }
.cstate-sub   { color:var(--muted); font-size:.85rem; line-height:1.65; }

/* ── PANELS ──────────────────────────────────────── */
.panel-wrap { position:fixed; inset:0; z-index:200; display:none; }
.panel-back { position:absolute; inset:0; background:rgba(26,18,8,.42); backdrop-filter:blur(5px); }
.panel-sheet { position:absolute; bottom:0; left:0; right:0; background:var(--surface); border-radius:24px 24px 0 0; max-height:88vh; display:flex; flex-direction:column; border-top:1.5px solid var(--border); box-shadow:0 -8px 40px rgba(0,0,0,.09); }
.panel-handle { width:36px; height:4px; background:var(--border); border-radius:4px; margin:11px auto 0; flex-shrink:0; }
.panel-head { display:flex; align-items:center; justify-content:space-between; padding:13px 20px; border-bottom:1px solid var(--border); flex-shrink:0; }
.panel-title { font-family:'Syne',sans-serif; font-weight:700; font-size:1.05rem; }
.panel-sub   { font-size:.74rem; color:var(--muted); margin-top:2px; }
.panel-close { width:29px; height:29px; background:var(--soft); border-radius:50%; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:.82rem; color:var(--muted); border:none; }
.panel-body  { overflow-y:auto; padding:14px 20px 32px; display:flex; flex-direction:column; gap:10px; flex:1; min-height:0; }

/* ── LIBRARY ITEM ────────────────────────────────── */
.lib-item { background:var(--bg); border:1.5px solid var(--border); border-radius:15px; overflow:hidden; cursor:pointer; transition:all .15s; display:flex; }
.lib-item:hover { border-color:#FFCBA0; transform:translateY(-1px); box-shadow:0 4px 12px rgba(255,107,53,.09); }
.lib-photo { width:76px; height:76px; object-fit:cover; flex-shrink:0; }
.lib-photo-ph { width:76px; height:76px; background:var(--peach); display:flex; align-items:center; justify-content:center; font-size:1.9rem; flex-shrink:0; }
.lib-info { padding:9px 11px; flex:1; min-width:0; }
.lib-name { font-family:'Syne',sans-serif; font-weight:700; font-size:.88rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.lib-meta { font-size:.7rem; color:var(--muted); margin-top:2px; font-weight:500; }
.lib-links { display:flex; gap:5px; margin-top:6px; flex-wrap:wrap; }
.lib-link { font-size:.67rem; padding:3px 8px; border-radius:7px; text-decoration:none; font-weight:600; border:1.5px solid; transition:opacity .15s; }
.lib-link:hover { opacity:.75; }
.ll-maps { border-color:#A8E6C1; background:var(--green-bg); color:var(--green); }
.ll-web  { border-color:#FFCBA0; background:var(--peach);    color:var(--accent); }
.ll-tel  { border-color:var(--border); background:var(--soft); color:var(--muted); }
.lib-rm  { padding:9px 11px; display:flex; align-items:center; justify-content:center; color:var(--muted); font-size:.82rem; cursor:pointer; border-left:1px solid var(--border); flex-shrink:0; transition:color .15s; }
.lib-rm:hover { color:var(--red); }
.panel-empty { text-align:center; padding:36px 16px; color:var(--muted); }
.panel-empty-icon { font-size:2.3rem; margin-bottom:9px; }
.panel-empty-text { font-size:.85rem; line-height:1.65; }

/* ── GROUP PANEL ─────────────────────────────────── */
.match-card { background:var(--peach); border:1.5px solid #FFCBA0; border-radius:16px; overflow:hidden; display:flex; }
.match-photo { width:70px; height:70px; object-fit:cover; flex-shrink:0; }
.match-photo-ph { width:70px; height:70px; background:var(--accent); display:flex; align-items:center; justify-content:center; font-size:1.8rem; flex-shrink:0; }
.match-info { padding:10px 13px; flex:1; min-width:0; }
.match-name { font-family:'Syne',sans-serif; font-weight:700; font-size:.9rem; }
.match-who  { font-size:.72rem; color:var(--accent); font-weight:600; margin-top:3px; }
.match-meta { font-size:.7rem; color:var(--muted); margin-top:2px; }

.progress-row { display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--border); font-size:.8rem; }
.progress-row:last-child { border:none; }
.prog-name { font-weight:600; display:flex; align-items:center; gap:7px; }
.prog-avatar { width:26px; height:26px; border-radius:50%; background:linear-gradient(135deg,var(--accent),var(--accent2)); display:flex; align-items:center; justify-content:center; font-family:'Syne',sans-serif; font-weight:800; font-size:.65rem; color:#fff; flex-shrink:0; }
.prog-bar-wrap { flex:1; margin:0 10px; height:5px; background:var(--border); border-radius:5px; overflow:hidden; }
.prog-bar-fill { height:100%; background:linear-gradient(90deg,var(--green),#1aab59); border-radius:5px; transition:width .5s ease; }
.prog-count { font-size:.72rem; color:var(--muted); min-width:32px; text-align:right; }

/* ── STATS ───────────────────────────────────────── */
.stats-grid { padding:14px 20px 32px; display:grid; grid-template-columns:1fr 1fr; gap:10px; overflow-y:auto; flex:1; min-height:0; }
.stat-card { background:var(--bg); border:1.5px solid var(--border); border-radius:15px; padding:14px 13px; display:flex; flex-direction:column; gap:3px; }
.stat-card.wide { grid-column:1 / -1; }
.stat-icon { font-size:1.5rem; margin-bottom:3px; }
.stat-val { font-family:'Syne',sans-serif; font-weight:800; font-size:1.7rem; color:var(--text); line-height:1; }
.stat-label { font-size:.7rem; color:var(--muted); font-weight:500; line-height:1.4; }
.cuisine-bars { display:flex; flex-direction:column; gap:7px; margin-top:6px; }
.cbar-row { display:flex; align-items:center; gap:8px; font-size:.74rem; }
.cbar-lbl { min-width:72px; color:var(--text); font-weight:600; }
.cbar-track { flex:1; height:6px; background:var(--border); border-radius:6px; overflow:hidden; }
.cbar-fill { height:100%; background:linear-gradient(90deg,var(--accent),var(--accent2)); border-radius:6px; transition:width .6s cubic-bezier(.34,1.56,.64,1); }
.cbar-num { min-width:22px; text-align:right; color:var(--muted); font-weight:600; }

/* ── DETAIL MODAL ────────────────────────────────── */
#detail-modal { position:fixed; inset:0; z-index:300; display:none; align-items:flex-end; justify-content:center; }
.detail-back { position:absolute; inset:0; background:rgba(26,18,8,.6); backdrop-filter:blur(8px); }
.detail-sheet { position:relative; background:var(--surface); border-radius:24px 24px 0 0; width:100%; max-width:480px; max-height:82vh; overflow-y:auto; border-top:1.5px solid var(--border); }
.det-photo { width:100%; height:210px; object-fit:cover; display:block; }
.det-ph    { width:100%; height:170px; background:linear-gradient(135deg,var(--peach),var(--soft)); display:flex; align-items:center; justify-content:center; font-size:4rem; }
.det-close { position:absolute; top:13px; right:13px; background:rgba(255,255,255,.92); border:none; border-radius:50%; width:32px; height:32px; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:.88rem; box-shadow:0 2px 8px rgba(0,0,0,.12); z-index:1; }
.det-body  { padding:17px 21px 28px; }
.det-cuisine { font-size:.65rem; text-transform:uppercase; letter-spacing:1.8px; color:var(--accent); font-family:'Syne',sans-serif; font-weight:700; }
.det-name { font-family:'Syne',sans-serif; font-weight:800; font-size:1.45rem; margin:4px 0 11px; line-height:1.1; }
.det-row { display:flex; align-items:flex-start; gap:9px; padding:8px 0; border-bottom:1px solid var(--border); font-size:.83rem; }
.det-row:last-of-type { border:none; }
.det-ico { width:29px; height:29px; background:var(--soft); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:.85rem; flex-shrink:0; }
.det-txt { flex:1; line-height:1.5; padding-top:5px; }
.det-txt a { color:var(--accent); text-decoration:none; }
.det-ctas { display:flex; gap:8px; margin-top:17px; flex-wrap:wrap; }
.det-cta  { flex:1; min-width:80px; padding:11px; border-radius:11px; border:1.5px solid; font-family:'Syne',sans-serif; font-weight:700; font-size:.8rem; text-align:center; text-decoration:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:5px; transition:opacity .15s; }
.det-cta:hover { opacity:.78; }
.dc-maps { background:var(--green-bg); border-color:#A8E6C1; color:var(--green); }
.dc-web  { background:var(--peach);    border-color:#FFCBA0; color:var(--accent); }
.dc-call { background:var(--soft);     border-color:var(--border); color:var(--text); }

/* ── TOAST ───────────────────────────────────────── */
.toast { position:fixed; top:70px; left:50%; transform:translateX(-50%) translateY(-14px); background:var(--text); color:#fff; padding:10px 20px; border-radius:100px; font-family:'Syne',sans-serif; font-weight:700; font-size:.83rem; pointer-events:none; opacity:0; transition:all .3s cubic-bezier(.34,1.56,.64,1); z-index:999; white-space:nowrap; box-shadow:0 6px 20px rgba(0,0,0,.18); }
.toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
.toast.green  { background:var(--green); }
.toast.orange { background:var(--accent); }
.toast.match  { background:linear-gradient(135deg,var(--accent),var(--accent2)); font-size:.88rem; padding:11px 22px; }

/* ── MATCH CELEBRATION ───────────────────────────── */
@keyframes popIn { 0%{transform:scale(.5) translateY(30px);opacity:0} 70%{transform:scale(1.05);opacity:1} 100%{transform:scale(1);opacity:1} }
.match-pop { animation:popIn .45s cubic-bezier(.34,1.56,.64,1) both; }

@media (min-width:480px) { .card-stack { height:490px; } }
</style>
</head>
<body>

<!-- ══ SPLASH ══════════════════════════════════════════ -->
<div id="splash" class="screen">
  <div class="screen-inner">
    <div class="logo-text logo-lg">Crave</div>
    <div class="tagline">Swipe your way to your next meal.</div>
    <div class="float-emojis">🍕 🍣 🍔 🌮 🍜</div>

    <div class="glass">
      <div>
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <span class="field-label" style="margin:0">Search radius</span>
          <span style="font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;color:var(--accent)" id="rad-display">3 km</span>
        </div>
        <input type="range" id="rad-slider" min="500" max="20000" step="500" value="3000">
      </div>

      <div>
        <span class="field-label">Cuisine</span>
        <div class="chips" id="filter-chips">
          <div class="chip on" data-f="">🍽️ All</div>
          <div class="chip" data-f="pizza">🍕 Pizza</div>
          <div class="chip" data-f="sushi">🍣 Sushi</div>
          <div class="chip" data-f="burger">🍔 Burgers</div>
          <div class="chip" data-f="vegan">🥗 Vegan</div>
          <div class="chip" data-f="cafe">☕ Café</div>
          <div class="chip" data-f="asian">🍜 Asian</div>
          <div class="chip" data-f="italian">🍝 Italian</div>
          <div class="chip" data-f="bar">🍺 Bar</div>
        </div>
      </div>

      <div>
        <span class="field-label">Mode</span>
        <div class="mode-row">
          <div class="mode-card selected" id="mode-solo" onclick="selectMode('solo')">
            <div class="mode-icon">🧍</div>
            <div class="mode-label">Solo</div>
            <div class="mode-sub">Swipe alone, save your matches</div>
          </div>
          <div class="mode-card" id="mode-group" onclick="selectMode('group')">
            <div class="mode-icon">👥</div>
            <div class="mode-label">Group</div>
            <div class="mode-sub">See where everyone agrees</div>
          </div>
        </div>
      </div>

      <div id="group-name-field" style="display:none">
        <span class="field-label">Your name (for the group)</span>
        <input type="text" id="creator-name" class="text-input" placeholder="e.g. Anton">
      </div>

      <button class="btn btn-primary" id="start-btn" onclick="startApp()">📍 Find Food Near Me</button>
      <div class="divider">or</div>
      <button class="btn btn-outline" onclick="showAuth('signup')">✨ Sign in for stats & history</button>

      <div id="join-section" style="text-align:center;font-size:.82rem;color:var(--muted);">
        Have a group link? <a style="color:var(--accent);cursor:pointer;font-weight:600;" onclick="showJoin()">Join here →</a>
      </div>
    </div>
  </div>
</div>

<!-- ══ AUTH ════════════════════════════════════════════ -->
<div id="auth-screen" class="screen hidden">
  <div class="screen-inner">
    <div class="logo-text logo-sm" style="margin-bottom:4px;">Crave</div>
    <div class="tagline" id="auth-tagline" style="margin-bottom:24px;">Create your account</div>

    <div class="glass" style="gap:13px;">
      <div class="perks" id="perks">
        <div class="perk"><div class="perk-ico">📊</div>Fun stats — top cuisines, streaks & more</div>
        <div class="perk"><div class="perk-ico">📚</div>Library saved across all your devices</div>
        <div class="perk"><div class="perk-ico">👥</div>Group history & who you matched with</div>
      </div>
      <input type="text"     id="auth-name"  class="text-input" placeholder="Your name" style="display:none">
      <input type="email"    id="auth-email" class="text-input" placeholder="Email">
      <input type="password" id="auth-pass"  class="text-input" placeholder="Password (6+ characters)">
      <button class="btn btn-primary" id="auth-btn" onclick="doAuth()">Create account</button>
      <div class="auth-toggle" id="auth-toggle">Already have an account? <a onclick="toggleAuthMode()">Sign in</a></div>
      <button class="btn btn-outline" onclick="goBack()" style="margin-top:-4px;">← Back</button>
    </div>
  </div>
</div>

<!-- ══ JOIN GROUP ══════════════════════════════════════ -->
<div id="join-screen" class="screen hidden">
  <div class="screen-inner">
    <div class="logo-text logo-sm" style="margin-bottom:4px;">Crave</div>
    <div class="tagline" style="margin-bottom:24px;">Join a group session</div>

    <div class="glass" style="gap:14px;">
      <div>
        <span class="field-label">Group code</span>
        <input type="text" id="join-code" class="text-input" placeholder="e.g. AB3XY" style="text-transform:uppercase;letter-spacing:3px;font-family:'Syne',sans-serif;font-weight:700;font-size:1.1rem;">
      </div>
      <div>
        <span class="field-label">Your name</span>
        <input type="text" id="join-name" class="text-input" placeholder="e.g. Vilma">
      </div>
      <button class="btn btn-green" onclick="joinGroup()">👥 Join Group</button>
      <button class="btn btn-outline" onclick="goBack()">← Back</button>
    </div>
  </div>
</div>

<!-- ══ GROUP LOBBY ═════════════════════════════════════ -->
<div id="lobby-screen" class="screen hidden">
  <div class="screen-inner">
    <div class="logo-text logo-sm" style="margin-bottom:4px;">Crave</div>
    <div class="tagline" id="lobby-sub" style="margin-bottom:24px;">Waiting for your crew…</div>

    <div class="glass" style="gap:16px;">
      <div class="share-box">
        <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;color:var(--accent);">Share this link with your group</div>
        <div class="share-url" id="share-url">—</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <button class="copy-btn" onclick="copyLink()">📋 Copy link</button>
          <button class="copy-btn" style="background:var(--green);" onclick="shareLink()">📲 Share</button>
        </div>
      </div>

      <div>
        <span class="field-label">Group members</span>
        <div class="member-list" id="lobby-members"></div>
      </div>

      <button class="btn btn-primary" id="lobby-start-btn" onclick="startSwiping()">🍽️ Start Swiping!</button>
      <div style="text-align:center;font-size:.76rem;color:var(--muted);">Others can join even after you start</div>
    </div>
  </div>
</div>

<!-- ══ MAIN APP ════════════════════════════════════════ -->
<div id="app">
  <div class="header">
    <div class="logo-text logo-sm">Crave</div>
    <div class="header-right">
      <div class="pill streak-pill" id="streak-pill" style="display:none">🔥 <span id="streak-num">0</span></div>
      <div class="pill group-pill" id="group-pill" style="display:none" onclick="openGroupPanel()">👥 Group</div>
      <div class="pill" onclick="openStats()">📊</div>
      <div class="pill" onclick="openLibrary()">📚 <div class="badge" id="lib-badge" style="display:none">0</div></div>
      <div class="pill" onclick="goBack()">⚙️</div>
    </div>
  </div>

  <div class="loc-bar" id="loc-bar">📍 Finding restaurants…</div>

  <div class="stack-wrap">
    <div class="cstate" id="loading-state" style="display:flex;">
      <div class="spinner"></div>
      <div style="color:var(--muted);font-size:.86rem;font-weight:600;font-family:'Syne',sans-serif;">Sniffing out restaurants…</div>
    </div>
    <div class="cstate" id="empty-state">
      <div class="cstate-emoji">🍽️</div>
      <div class="cstate-title">You've seen them all!</div>
      <div class="cstate-sub">No more restaurants nearby.<br>Check your library or try a wider radius.</div>
      <button class="btn btn-primary" style="max-width:200px;margin-top:8px;" onclick="openLibrary()">Open Library 📚</button>
    </div>
    <div class="card-stack" id="card-stack"></div>
  </div>

  <div class="action-bar">
    <button class="act a-undo" onclick="rewind()"             title="Undo">↩️</button>
    <button class="act a-skip" onclick="swipeCard('left')"    title="Skip">✕</button>
    <button class="act a-save" onclick="swipeCard('right')"   title="Save">♥</button>
    <button class="act a-info" onclick="showDetail(currentR())" title="Info">ℹ️</button>
    <button class="act a-dice" onclick="pickForMe()"          title="Surprise me">🎲</button>
  </div>
  <div class="kbd-hint"><span class="kbd">←</span> skip &nbsp;<span class="kbd">→</span> save &nbsp;<span class="kbd">I</span> info &nbsp;<span class="kbd">Z</span> undo</div>
</div>

<!-- ══ LIBRARY PANEL ═══════════════════════════════════ -->
<div id="lib-panel" class="panel-wrap">
  <div class="panel-back" onclick="closeLibrary()"></div>
  <div class="panel-sheet">
    <div class="panel-handle"></div>
    <div class="panel-head">
      <div><div class="panel-title">My Cravings 📚</div><div class="panel-sub" id="lib-sub">Saved restaurants</div></div>
      <button class="panel-close" onclick="closeLibrary()">✕</button>
    </div>
    <div style="padding:10px 20px 4px;flex-shrink:0;">
      <button class="btn btn-outline" style="gap:8px;" onclick="pickForMe()">🎲 Pick one for me tonight</button>
    </div>
    <div class="panel-body" id="lib-list"></div>
  </div>
</div>

<!-- ══ GROUP PANEL ═════════════════════════════════════ -->
<div id="group-panel" class="panel-wrap">
  <div class="panel-back" onclick="closeGroupPanel()"></div>
  <div class="panel-sheet">
    <div class="panel-handle"></div>
    <div class="panel-head">
      <div><div class="panel-title">Group Matches 👥</div><div class="panel-sub" id="group-panel-sub">See what everyone agreed on</div></div>
      <button class="panel-close" onclick="closeGroupPanel()">✕</button>
    </div>
    <div class="panel-body" id="group-panel-body"></div>
  </div>
</div>

<!-- ══ STATS PANEL ═════════════════════════════════════ -->
<div id="stats-panel" class="panel-wrap">
  <div class="panel-back" onclick="closeStats()"></div>
  <div class="panel-sheet">
    <div class="panel-handle"></div>
    <div class="panel-head">
      <div><div class="panel-title">Your Food Journey 📊</div><div class="panel-sub" id="stats-sub">All time</div></div>
      <button class="panel-close" onclick="closeStats()">✕</button>
    </div>
    <div id="stats-body" class="stats-grid" style="padding:14px 20px 32px;overflow-y:auto;flex:1;min-height:0;"></div>
  </div>
</div>

<!-- ══ DETAIL MODAL ════════════════════════════════════ -->
<div id="detail-modal">
  <div class="detail-back" onclick="closeDetail()"></div>
  <div class="detail-sheet" id="detail-sheet"></div>
</div>

<div class="toast" id="toast"></div>

<script>
// ════════════════════════════════════════════════════
//  STATE
// ════════════════════════════════════════════════════
let restaurants = [], currentIndex = 0;
let library     = JSON.parse(localStorage.getItem('crave_lib')  || '[]');
let swipeHist   = [];
let streak = 0, selectedFilter = '', searchRadius = 3000;
let userLat = null, userLng = null;
let appMode = 'solo'; // 'solo' | 'group'

// Group state
let groupCode = null, groupMemberId = null, groupMemberName = null;
let groupSession = null, groupPollInterval = null;

// Drag
let isDrag = false, sx = 0, sy = 0, cx = 0;

// Auth
let authMode = 'signup';
let currentUser  = JSON.parse(localStorage.getItem('crave_user')  || 'null');
let userStats    = JSON.parse(localStorage.getItem('crave_stats') || JSON.stringify({
  totalSwiped:0, totalSaved:0, totalSkipped:0,
  longestStreak:0, cuisineCounts:{}, sessions:0,
  firstSwipe:null, lastSwipe:null,
}));

// ════════════════════════════════════════════════════
//  SCREEN HELPERS
// ════════════════════════════════════════════════════
const SCREENS = ['splash','auth-screen','join-screen','lobby-screen'];
function showScreen(id) {
  SCREENS.forEach(s => document.getElementById(s).classList.toggle('hidden', s !== id));
  document.getElementById('app').style.display = 'none';
}
function showSplash() { showScreen('splash'); stopGroupPoll(); }
function showAuth(m) { authMode = m || 'signup'; applyAuthMode(); showScreen('auth-screen'); }
function showJoin()  { showScreen('join-screen'); checkUrlCode(); }
function goBack()    { showSplash(); }

// Check if URL has a join code e.g. ?join=ABC12
function checkUrlCode() {
  const p = new URLSearchParams(window.location.search);
  const c = p.get('join');
  if (c) { document.getElementById('join-code').value = c.toUpperCase(); }
}

// ════════════════════════════════════════════════════
//  SETUP UI
// ════════════════════════════════════════════════════
document.getElementById('rad-slider').addEventListener('input', function() {
  const v = parseInt(this.value); searchRadius = v;
  document.getElementById('rad-display').textContent = v >= 1000 ? `${v/1000} km` : `${v}m`;
});

document.querySelectorAll('#filter-chips .chip').forEach(c => {
  c.addEventListener('click', () => {
    document.querySelectorAll('#filter-chips .chip').forEach(x => x.classList.remove('on'));
    c.classList.add('on'); selectedFilter = c.dataset.f;
  });
});

function selectMode(m) {
  appMode = m;
  document.getElementById('mode-solo').classList.toggle('selected', m === 'solo');
  document.getElementById('mode-group').classList.toggle('selected', m === 'group');
  document.getElementById('group-name-field').style.display = m === 'group' ? 'block' : 'none';
}

// ════════════════════════════════════════════════════
//  AUTH
// ════════════════════════════════════════════════════
function applyAuthMode() {
  const su = authMode === 'signup';
  document.getElementById('auth-tagline').textContent = su ? 'Create your account' : 'Welcome back';
  document.getElementById('auth-btn').textContent    = su ? 'Create account' : 'Sign in';
  document.getElementById('auth-toggle').innerHTML   = su
    ? 'Already have an account? <a onclick="toggleAuthMode()">Sign in</a>'
    : "Don't have an account? <a onclick=\"toggleAuthMode()\">Sign up</a>";
  document.getElementById('auth-name').style.display  = su ? 'block' : 'none';
  document.getElementById('perks').style.display      = su ? 'flex'  : 'none';
}
function toggleAuthMode() { authMode = authMode === 'signup' ? 'signin' : 'signup'; applyAuthMode(); }

function doAuth() {
  const email = document.getElementById('auth-email').value.trim();
  const pass  = document.getElementById('auth-pass').value;
  const name  = document.getElementById('auth-name').value.trim();
  if (!email || !pass) { toast('⚠️ Fill in email and password'); return; }
  if (authMode === 'signup' && pass.length < 6) { toast('⚠️ Password needs 6+ characters'); return; }

  if (authMode === 'signup') {
    currentUser = { email, name: name || email.split('@')[0], joinedAt: Date.now() };
    localStorage.setItem('crave_user', JSON.stringify(currentUser));
    toast(`👋 Welcome, ${currentUser.name}!`, 'green');
  } else {
    const stored = localStorage.getItem('crave_user');
    if (!stored) { toast('⚠️ No account found — sign up first'); return; }
    currentUser = JSON.parse(stored);
    toast(`👋 Welcome back, ${currentUser.name}!`, 'green');
  }
  userStats.sessions++;
  saveStats();
  showSplash();
}

// ════════════════════════════════════════════════════
//  START APP
// ════════════════════════════════════════════════════
function startApp() {
  if (appMode === 'group') {
    const n = document.getElementById('creator-name').value.trim();
    if (!n) { toast('⚠️ Enter your name for the group'); return; }
    groupMemberName = n;
  }

  const btn = document.getElementById('start-btn');
  btn.disabled = true; btn.textContent = '📍 Getting location…';

  SCREENS.forEach(s => document.getElementById(s).classList.add('hidden'));

  if (!navigator.geolocation) { btn.disabled=false; btn.innerHTML='📍 Find Food Near Me'; doFetch(59.3326,18.0649); return; }

  navigator.geolocation.getCurrentPosition(
    pos => { userLat=pos.coords.latitude; userLng=pos.coords.longitude; btn.disabled=false; btn.innerHTML='📍 Find Food Near Me'; doFetch(userLat,userLng); },
    ()  => { userLat=59.3326; userLng=18.0649; btn.disabled=false; btn.innerHTML='📍 Find Food Near Me'; doFetch(userLat,userLng); document.getElementById('loc-bar').textContent='📍 Stockholm (location unavailable)'; },
    { enableHighAccuracy:true, timeout:12000 }
  );
}

async function doFetch(lat, lng) {
  // Show loading in app
  document.getElementById('app').style.display = 'flex';
  document.getElementById('app').style.flexDirection = 'column';
  document.getElementById('loading-state').style.display = 'flex';
  document.getElementById('card-stack').innerHTML = '';
  document.getElementById('empty-state').style.display = 'none';

  const params = new URLSearchParams({ lat, lng, radius: searchRadius, ...(selectedFilter ? { keyword: selectedFilter } : {}) });
  try {
    const res  = await fetch(`/api/nearby?${params}`);
    const data = await res.json();
    if (data.status === 'OK' && data.results?.length) {
      const seen = JSON.parse(localStorage.getItem('crave_seen') || '[]');
      restaurants = data.results
        .filter(r => !seen.includes(r.place_id))
        .map(r => {
          const d = distKm(lat,lng,r.geometry.location.lat,r.geometry.location.lng);
          r.distance = d < 1 ? `${Math.round(d*1000)}m` : `${d.toFixed(1)} km`;
          r.cuisine  = (r.types||[]).filter(t=>!['establishment','point_of_interest','food','restaurant'].includes(t))[0]?.replace(/_/g,' ') || 'Restaurant';
          return r;
        });
      const rl = searchRadius>=1000 ? `${searchRadius/1000} km` : `${searchRadius}m`;
      document.getElementById('loc-bar').textContent = `📍 ${restaurants.length} restaurants within ${rl}`;

      if (appMode === 'group') {
        await createGroup(restaurants);
      } else {
        currentIndex = 0; swipeHist = [];
        renderStack();
        userStats.sessions++;
        saveStats();
      }
    } else {
      document.getElementById('loading-state').style.display = 'none';
      document.getElementById('empty-state').style.display = 'flex';
    }
  } catch(e) {
    console.error(e);
    document.getElementById('loading-state').style.display = 'none';
    toast('⚠️ Could not load restaurants');
  }
}

function distKm(lat1,lon1,lat2,lon2) {
  const R=6371,dLat=(lat2-lat1)*Math.PI/180,dLon=(lon2-lon1)*Math.PI/180;
  const a=Math.sin(dLat/2)**2+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}

// ════════════════════════════════════════════════════
//  GROUP FLOW
// ════════════════════════════════════════════════════
async function createGroup(rests) {
  try {
    const res  = await fetch('/api/group?action=create', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        creatorName: groupMemberName,
        restaurants: rests.map(r => ({
          place_id: r.place_id, name: r.name, cuisine: r.cuisine,
          distance: r.distance, rating: r.rating, user_ratings_total: r.user_ratings_total,
          photos: r.photos, opening_hours: r.opening_hours, vicinity: r.vicinity,
        })),
        lat: userLat, lng: userLng, radius: searchRadius, keyword: selectedFilter,
      }),
    });
    const data = await res.json();
    if (!data.ok) throw new Error(data.error);
    groupCode      = data.code;
    groupMemberId  = data.memberId;
    groupSession   = null;

    // Hide app loading, show lobby
    document.getElementById('app').style.display = 'none';
    const url = `${location.origin}${location.pathname}?join=${groupCode}`;
    document.getElementById('share-url').textContent = url;
    document.getElementById('lobby-sub').textContent = `Group code: ${groupCode}`;
    document.getElementById('group-pill').style.display = 'flex';
    showScreen('lobby-screen');

    startGroupPoll();
  } catch(e) {
    console.error(e);
    document.getElementById('loading-state').style.display = 'none';
    toast('⚠️ Could not create group');
  }
}

async function joinGroup() {
  const code = document.getElementById('join-code').value.trim().toUpperCase();
  const name = document.getElementById('join-name').value.trim();
  if (!code || code.length < 4) { toast('⚠️ Enter the group code'); return; }
  if (!name)                    { toast('⚠️ Enter your name');       return; }

  try {
    const res  = await fetch('/api/group?action=join', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ code, name }),
    });
    const data = await res.json();
    if (!data.ok) { toast(`⚠️ ${data.error}`); return; }

    groupCode      = code;
    groupMemberId  = data.memberId;
    groupMemberName= name;
    groupSession   = data.session;
    restaurants    = data.session.restaurants;

    // Clean URL
    window.history.replaceState({}, '', window.location.pathname);

    document.getElementById('group-pill').style.display = 'flex';
    currentIndex = 0; swipeHist = [];

    showScreen('__none__');
    SCREENS.forEach(s => document.getElementById(s).classList.add('hidden'));
    document.getElementById('app').style.display = 'flex';
    document.getElementById('app').style.flexDirection = 'column';
    document.getElementById('loading-state').style.display = 'none';
    document.getElementById('loc-bar').textContent = `👥 Group: ${code} — ${restaurants.length} restaurants`;
    appMode = 'group';
    renderStack();
    startGroupPoll();
  } catch(e) {
    console.error(e);
    toast('⚠️ Could not join group');
  }
}

function startSwiping() {
  showScreen('__none__');
  SCREENS.forEach(s => document.getElementById(s).classList.add('hidden'));
  document.getElementById('app').style.display = 'flex';
  document.getElementById('app').style.flexDirection = 'column';
  document.getElementById('loading-state').style.display = 'none';
  document.getElementById('loc-bar').textContent = `👥 Group ${groupCode} — ${restaurants.length} restaurants`;
  currentIndex = 0; swipeHist = [];
  renderStack();
}

function startGroupPoll() {
  stopGroupPoll();
  groupPollInterval = setInterval(pollGroupState, 3500);
}
function stopGroupPoll() {
  if (groupPollInterval) { clearInterval(groupPollInterval); groupPollInterval = null; }
}

async function pollGroupState() {
  if (!groupCode) return;
  try {
    const res  = await fetch(`/api/group?action=state&code=${groupCode}`);
    const data = await res.json();
    if (!data.ok) return;
    const prev = groupSession;
    groupSession = data.session;
    updateLobbyUI();

    // Detect new group matches
    if (prev && groupSession.matches.length > prev.matches.length) {
      const newMatches = groupSession.matches.filter(m =>
        !prev.matches.find(pm => pm.placeId === m.placeId)
      );
      newMatches.forEach(m => {
        const who = m.names.join(' & ');
        toast(`🎉 ${who} matched: ${m.restaurant?.name}!`, 'match');
      });
    }
  } catch {}
}

function updateLobbyUI() {
  if (!groupSession) return;
  const members = groupSession.members;
  const total   = groupSession.restaurants?.length || 0;

  // Lobby member list
  const lobbyEl = document.getElementById('lobby-members');
  if (lobbyEl) {
    lobbyEl.innerHTML = members.map(m => {
      const swiped = Object.keys(m.swipes || {}).length;
      const pct    = total ? Math.round(swiped/total*100) : 0;
      return `<div class="member-row">
        <div class="member-avatar">${m.name[0].toUpperCase()}</div>
        <div class="member-name">${m.name}</div>
        ${swiped >= total && total > 0
          ? '<div class="member-done">✓ Done!</div>'
          : `<div class="member-prog">${swiped}/${total}</div>`}
      </div>`;
    }).join('');
  }

  document.getElementById('group-panel-sub').textContent =
    `${members.length} member${members.length!==1?'s':''} · ${groupSession.matches.length} shared match${groupSession.matches.length!==1?'es':''}`;
}

function copyLink() {
  const url = document.getElementById('share-url').textContent;
  navigator.clipboard.writeText(url).then(() => toast('📋 Link copied!', 'green'));
}

function shareLink() {
  const url = document.getElementById('share-url').textContent;
  if (navigator.share) {
    navigator.share({ title:'Join my Crave group!', text:`Swipe restaurants with me 🍽️`, url });
  } else {
    copyLink();
  }
}

// ════════════════════════════════════════════════════
//  RENDER CARDS
// ════════════════════════════════════════════════════
function emo(c='') {
  const t=c.toLowerCase();
  if(t.includes('pizza'))  return '🍕';
  if(t.includes('sushi')||t.includes('japanese')) return '🍣';
  if(t.includes('burger')) return '🍔';
  if(t.includes('vegan'))  return '🥗';
  if(t.includes('cafe')||t.includes('coffee'))    return '☕';
  if(t.includes('italian'))return '🍝';
  if(t.includes('asian')||t.includes('chinese')||t.includes('thai')) return '🍜';
  if(t.includes('indian')) return '🍛';
  if(t.includes('mexican'))return '🌮';
  if(t.includes('bar'))    return '🍺';
  if(t.includes('seafood'))return '🦞';
  return '🍽️';
}
function photoUrl(r, w=800) {
  if (!r.photos?.[0]?.photo_reference) return null;
  return `/api/photo?ref=${encodeURIComponent(r.photos[0].photo_reference)}&maxwidth=${w}`;
}

function renderStack() {
  document.getElementById('loading-state').style.display = 'none';
  const stack = document.getElementById('card-stack');
  stack.innerHTML = '';
  const rem = restaurants.slice(currentIndex);
  if (!rem.length) { document.getElementById('empty-state').style.display='flex'; return; }
  document.getElementById('empty-state').style.display='none';

  rem.slice(0,3).reverse().forEach((r,i,arr) => {
    const pos = arr.length-1-i;
    const card = makeCard(r);
    card.className = 'r-card ' + (['peek-2','peek-1','top'][pos]||'peek-2');
    stack.appendChild(card);
  });
  setupDrag();
}

function makeCard(r) {
  const div = document.createElement('div');
  div.dataset.pid = r.place_id;
  const src  = photoUrl(r);
  const em   = emo(r.cuisine);
  const open = r.opening_hours ? (r.opening_hours.open_now ? '🟢 Open':'🔴 Closed') : '';

  // Check if group members already swiped right on this
  let alsoLiked = '';
  if (appMode==='group' && groupSession) {
    const fans = groupSession.members
      .filter(m => m.id !== groupMemberId && m.swipes?.[r.place_id] === 'right')
      .map(m => m.name);
    if (fans.length) alsoLiked = `❤️ ${fans.join(' & ')} liked this`;
  }

  div.innerHTML = `
    <div class="r-shimmer">
      <div class="r-shimmer-emoji">${em}</div>
      <div class="r-shimmer-bar"></div>
    </div>
    ${src ? `<img class="r-photo" src="${src}" alt="${r.name}" loading="eager"
      onload="this.style.opacity=1"
      onerror="this.style.display='none'"
      style="opacity:0;transition:opacity .35s;">` : ''}
    <div class="swipe-lbl lbl-save">SAVE</div>
    <div class="swipe-lbl lbl-skip">SKIP</div>
    ${alsoLiked ? `<div class="also-liked" style="display:block">${alsoLiked}</div>` : ''}
    <div class="r-overlay">
      <div class="r-cuisine">${r.cuisine.toUpperCase()}</div>
      <div class="r-name">${r.name}</div>
      <div class="r-meta">
        ${r.rating ? `<span>⭐ ${r.rating} <span style="opacity:.65">(${(r.user_ratings_total||0).toLocaleString()})</span></span>` : ''}
        <span>📍 ${r.distance}</span>
        ${open ? `<span>${open}</span>` : ''}
      </div>
    </div>`;
  return div;
}

// ════════════════════════════════════════════════════
//  DRAG
// ════════════════════════════════════════════════════
function setupDrag() {
  const top = document.querySelector('.r-card.top');
  if (!top) return;
  let moved = false;

  const start = e => { isDrag=true; moved=false; const t=e.touches?.[0]||e; sx=t.clientX; sy=t.clientY; cx=0; top.style.transition='none'; };
  const move  = e => {
    if (!isDrag) return; e.preventDefault(); moved=true;
    const t=e.touches?.[0]||e; cx=t.clientX-sx;
    const dy=(t.clientY-sy)*.2;
    top.style.transform=`translateX(${cx}px) translateY(${dy}px) rotate(${cx*.07}deg)`;
    const r=Math.min(Math.abs(cx)/80,1);
    top.querySelector('.lbl-save').style.opacity = cx>0?r:0;
    top.querySelector('.lbl-skip').style.opacity = cx<0?r:0;
  };
  const end = () => {
    if (!isDrag) return; isDrag=false;
    if (moved && Math.abs(cx)>80) swipeCard(cx>0?'right':'left',top);
    else { top.style.transition='transform .4s cubic-bezier(.34,1.56,.64,1)'; top.style.transform=''; top.querySelector('.lbl-save').style.opacity=0; top.querySelector('.lbl-skip').style.opacity=0; }
    cx=0;
  };
  top.addEventListener('mousedown', start);
  top.addEventListener('touchstart', start, {passive:false});
  window.addEventListener('mousemove', move);
  window.addEventListener('touchmove', move, {passive:false});
  window.addEventListener('mouseup', end);
  window.addEventListener('touchend', end);
}

// ════════════════════════════════════════════════════
//  SWIPE ACTIONS
// ════════════════════════════════════════════════════
function currentR() { return restaurants[currentIndex]; }

async function swipeCard(dir, cardEl) {
  const stack = document.getElementById('card-stack');
  const top   = cardEl || stack.querySelector('.r-card.top');
  const r     = restaurants[currentIndex];
  if (!top || !r) return;

  swipeHist.push({ r, index:currentIndex, saved:dir==='right' });
  markSeen(r.place_id);

  top.style.transition = 'transform .35s ease, opacity .25s ease';
  top.style.transform  = `translateX(${dir==='right'?120:-120}vw) rotate(${dir==='right'?20:-20}deg)`;
  top.style.opacity    = '0';

  // Stats
  userStats.totalSwiped++;
  userStats.lastSwipe = Date.now();
  if (!userStats.firstSwipe) userStats.firstSwipe = Date.now();

  if (dir === 'right') {
    saveToLibrary(r);
    userStats.totalSaved++;
    const c = r.cuisine||'Restaurant';
    userStats.cuisineCounts[c] = (userStats.cuisineCounts[c]||0)+1;
    streak++;
    if (streak > userStats.longestStreak) userStats.longestStreak = streak;
    toast(`💚 Saved: ${r.name}`, 'green');
  } else {
    userStats.totalSkipped++;
    streak=0;
  }
  updateStreak();
  saveStats();

  // Group swipe
  if (appMode==='group' && groupCode) {
    // Fire and forget
    fetch('/api/group?action=swipe', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ code:groupCode, memberId:groupMemberId, placeId:r.place_id, direction:dir }),
    }).then(res => res.json()).then(data => {
      if (data.ok) {
        groupSession = data.session;
        // Check if this swipe created a NEW match
        const newMatches = data.session.matches.filter(m =>
          m.placeId === r.place_id && m.names.length >= 2
        );
        if (newMatches.length) {
          const who = newMatches[0].names.filter(n=>n!==groupMemberName).join(' & ');
          toast(`🎉 You & ${who} matched: ${r.name}!`, 'match');
        }
      }
    }).catch(()=>{});
  }

  currentIndex++;
  setTimeout(() => {
    top.remove();
    promoteCards();
    if (currentIndex >= restaurants.length) document.getElementById('empty-state').style.display='flex';
    else if (document.querySelectorAll('.r-card').length < 3) renderStack();
  }, 330);
}

function promoteCards() {
  const cards = [...document.querySelectorAll('.r-card')].reverse();
  const cls   = ['top','peek-1','peek-2'];
  cards.forEach((c,i) => { c.className='r-card'+(cls[i]?' '+cls[i]:''); if(i===0) setupDrag(); });
}

function rewind() {
  if (!swipeHist.length) return;
  const prev = swipeHist.pop();
  currentIndex = prev.index;
  if (prev.saved) removeFromLibrary(prev.r.place_id);
  streak = Math.max(0,streak-1);
  updateStreak();
  renderStack();
  toast('↩️ Undone');
}

function markSeen(id) {
  const s = JSON.parse(localStorage.getItem('crave_seen')||'[]');
  if (!s.includes(id)) { s.push(id); localStorage.setItem('crave_seen',JSON.stringify(s)); }
}

// ════════════════════════════════════════════════════
//  LIBRARY
// ════════════════════════════════════════════════════
function saveToLibrary(r) {
  if (library.find(x=>x.place_id===r.place_id)) return;
  library.unshift(r);
  localStorage.setItem('crave_lib',JSON.stringify(library));
  updateLibBadge();
}
function removeFromLibrary(id) {
  library = library.filter(r=>r.place_id!==id);
  localStorage.setItem('crave_lib',JSON.stringify(library));
  updateLibBadge();
}
function updateLibBadge() {
  const n=library.length, b=document.getElementById('lib-badge');
  b.textContent=n; b.style.display=n>0?'flex':'none';
  document.getElementById('lib-sub').textContent=`${n} saved restaurant${n!==1?'s':''}`;
}
function openLibrary()  { document.getElementById('lib-panel').style.display='block'; renderLibrary(); }
function closeLibrary() { document.getElementById('lib-panel').style.display='none'; }

function renderLibrary() {
  const list = document.getElementById('lib-list');
  if (!library.length) {
    list.innerHTML=`<div class="panel-empty"><div class="panel-empty-icon">🍽️</div><div class="panel-empty-text">Nothing saved yet.<br>Swipe right on restaurants you love!</div></div>`;
    return;
  }
  list.innerHTML = library.map(r => {
    const src  = photoUrl(r,200);
    const em   = emo(r.cuisine);
    const maps = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(r.name)}&query_place_id=${r.place_id}`;
    return `
      <div class="lib-item" onclick="showDetail(library.find(x=>x.place_id==='${r.place_id}'))">
        ${src?`<img class="lib-photo" src="${src}" alt="${r.name}" loading="lazy" onerror="this.outerHTML='<div class=lib-photo-ph>${em}</div>'">`:`<div class="lib-photo-ph">${em}</div>`}
        <div class="lib-info">
          <div class="lib-name">${r.name}</div>
          <div class="lib-meta">${r.rating?`⭐ ${r.rating} · `:''}📍 ${r.distance}</div>
          <div class="lib-links">
            <a class="lib-link ll-maps" href="${maps}" target="_blank" onclick="event.stopPropagation()">🗺 Maps</a>
            ${r.website?`<a class="lib-link ll-web" href="${r.website}" target="_blank" onclick="event.stopPropagation()">🌐 Site</a>`:''}
            ${r.formatted_phone_number?`<a class="lib-link ll-tel" href="tel:${r.formatted_phone_number}" onclick="event.stopPropagation()">📞</a>`:''}
          </div>
        </div>
        <div class="lib-rm" onclick="event.stopPropagation();removeFromLibrary('${r.place_id}');renderLibrary()">✕</div>
      </div>`;
  }).join('');
}

function pickForMe() {
  if (!library.length) { toast('💡 Save some restaurants first!','orange'); return; }
  const r=library[Math.floor(Math.random()*library.length)];
  closeLibrary();
  showDetail(r);
  toast(`🎲 Tonight: ${r.name}`,'orange');
}

// ════════════════════════════════════════════════════
//  GROUP PANEL
// ════════════════════════════════════════════════════
function openGroupPanel()  { document.getElementById('group-panel').style.display='block'; renderGroupPanel(); }
function closeGroupPanel() { document.getElementById('group-panel').style.display='none'; }

function renderGroupPanel() {
  if (!groupSession) return;
  const body    = document.getElementById('group-panel-body');
  const total   = groupSession.restaurants?.length || 0;
  const members = groupSession.members;
  const matches = groupSession.matches;

  let html = '';

  // Member progress
  html += `<div style="padding:0 20px 4px;flex-shrink:0;">
    <div class="field-label" style="margin-bottom:10px;">Swipe progress</div>
    ${members.map(m => {
      const n   = Object.keys(m.swipes||{}).length;
      const pct = total ? Math.round(n/total*100) : 0;
      return `<div class="progress-row">
        <div class="prog-name"><div class="prog-avatar">${m.name[0].toUpperCase()}</div>${m.name}</div>
        <div class="prog-bar-wrap"><div class="prog-bar-fill" style="width:${pct}%"></div></div>
        <div class="prog-count">${n}/${total}</div>
      </div>`;
    }).join('')}
  </div>`;

  // Matches
  if (matches.length) {
    html += `<div style="padding:12px 20px 0;flex-shrink:0;"><div class="field-label">🎉 Shared matches</div></div>`;
    html += matches.map(m => {
      const r   = m.restaurant;
      const src = r ? photoUrl(r,200) : null;
      const em  = r ? emo(r.cuisine) : '🍽️';
      const who = m.names.join(' & ');
      return `
        <div class="match-card match-pop" onclick="showDetail(groupSession?.restaurants?.find(x=>x.place_id==='${m.placeId}'))">
          ${src?`<img class="match-photo" src="${src}" alt="${r?.name||''}" onerror="this.outerHTML='<div class=match-photo-ph>${em}</div>'">`:`<div class="match-photo-ph">${em}</div>`}
          <div class="match-info">
            <div class="match-name">${r?.name||'Restaurant'}</div>
            <div class="match-who">❤️ ${who}</div>
            <div class="match-meta">${r?.rating?`⭐ ${r.rating} · `:''}${r?.distance||''}</div>
          </div>
        </div>`;
    }).join('');
  } else {
    html += `<div class="panel-empty" style="padding:20px;"><div class="panel-empty-icon">👥</div><div class="panel-empty-text">No shared matches yet.<br>Keep swiping — matches appear when 2+ people agree!</div></div>`;
  }

  body.innerHTML = `<div style="display:flex;flex-direction:column;gap:10px;overflow-y:auto;padding:0 0 32px;">${html}</div>`;
}

// ════════════════════════════════════════════════════
//  STATS
// ════════════════════════════════════════════════════
function saveStats()   { localStorage.setItem('crave_stats',JSON.stringify(userStats)); }
function openStats()   { document.getElementById('stats-panel').style.display='block'; renderStats(); }
function closeStats()  { document.getElementById('stats-panel').style.display='none'; }

function renderStats() {
  const body = document.getElementById('stats-body');

  if (!currentUser) {
    document.getElementById('stats-sub').textContent = 'Guest mode';
    body.style.display = 'flex';
    body.style.gridTemplateColumns = 'unset';
    body.innerHTML = `
      <div style="text-align:center;padding:28px 16px;color:var(--muted);font-size:.85rem;line-height:1.7;flex:1;">
        <div style="font-size:2.5rem;margin-bottom:12px;">📊</div>
        <strong style="color:var(--text);">Sign up to unlock your full food profile!</strong><br><br>
        See top cuisines, save streaks, restaurants explored, group history, and more.
        <br><br>
        <button class="btn btn-primary" onclick="closeStats();showAuth('signup');" style="max-width:220px;margin:0 auto;">✨ Create account</button>
      </div>`;
    return;
  }

  body.style.display = 'grid';
  body.style.gridTemplateColumns = '1fr 1fr';
  document.getElementById('stats-sub').textContent = `Hey ${currentUser.name} 👋`;

  const cuisines  = Object.entries(userStats.cuisineCounts||{}).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const maxC      = cuisines[0]?.[1] || 1;
  const daysSince = userStats.firstSwipe ? Math.max(1,Math.round((Date.now()-userStats.firstSwipe)/86400000)) : 1;
  const rate      = userStats.totalSwiped>0 ? Math.round(userStats.totalSaved/userStats.totalSwiped*100) : 0;
  const verdict   = rate>60?'😋 You love everything!':rate>35?'🧐 Picky but fair':rate>15?'🕵️ Very selective':'😤 Hard to please';

  body.innerHTML = `
    <div class="stat-card"><div class="stat-icon">👆</div><div class="stat-val">${userStats.totalSwiped}</div><div class="stat-label">restaurants swiped</div></div>
    <div class="stat-card"><div class="stat-icon">💚</div><div class="stat-val">${userStats.totalSaved}</div><div class="stat-label">restaurants saved</div></div>
    <div class="stat-card"><div class="stat-icon">🔥</div><div class="stat-val">${userStats.longestStreak}</div><div class="stat-label">longest save streak</div></div>
    <div class="stat-card"><div class="stat-icon">🎯</div><div class="stat-val">${rate}%</div><div class="stat-label">acceptance rate<br><span style="font-size:.68rem;font-weight:400;">${verdict}</span></div></div>
    <div class="stat-card"><div class="stat-icon">📅</div><div class="stat-val">${daysSince}</div><div class="stat-label">days exploring</div></div>
    <div class="stat-card"><div class="stat-icon">🗺️</div><div class="stat-val">${userStats.sessions}</div><div class="stat-label">sessions</div></div>
    <div class="stat-card wide">
      <div class="stat-icon">🍽️</div>
      <div class="stat-label" style="font-size:.8rem;font-weight:700;color:var(--text);margin-bottom:10px;">Top cuisines</div>
      ${cuisines.length
        ? `<div class="cuisine-bars">${cuisines.map(([c,n])=>`
            <div class="cbar-row">
              <div class="cbar-lbl">${emo(c)} ${c}</div>
              <div class="cbar-track"><div class="cbar-fill" style="width:${Math.round(n/maxC*100)}%"></div></div>
              <div class="cbar-num">${n}</div>
            </div>`).join('')}</div>`
        : '<div style="color:var(--muted);font-size:.8rem;">Start swiping to see your top cuisines!</div>'
      }
    </div>`;
}

